#!/usr/bin/env bash
# Fetch secrets from Bitwarden and cache to .matedata/secrets.json

set -euo pipefail

SECRETS_FILE="{{ .SourceDir }}/.matedata/secrets.json"
EMAIL="{{ .Vars.email }}"

# Table: "output.dot.path | item_name | type | detail"
# Types:
#   field      - custom field value on an item (detail: field name)
#   ssh        - SSH Key item type             (detail: "private" or "public")
#   attachment - file attachment, base64-enc   (detail: filename)
SECRETS=(
  "chezmoi.age_key          | chezmoi  | field      | age-key"
  "chezmoi.age_key_pub      | chezmoi  | field      | age-key-pub"
{{ range .Vars.sshKeys -}}
  "ssh.{{ . }}.private      | {{ . }}  | ssh        | private"
  "ssh.{{ . }}.public       | {{ . }}  | ssh        | public"
{{ end -}}
{{ range .Vars.authorizedSshKeys -}}
  "ssh.{{ . }}.public       | {{ . }}  | ssh        | public"
{{ end -}}
  "gpg.priv_asc             | gpg-keys | attachment | ${EMAIL}.priv.asc"
  "gpg.pub_asc              | gpg-keys | attachment | ${EMAIL}.pub.asc"
  "gpg.sub_priv_asc         | gpg-keys | attachment | ${EMAIL}.sub_priv.asc"
  "github.cli_token         | github.com | field    | gh-cli-token"
  "jira.api_token           | atlassian.com-jamf | field | api-key"
  "sonarqube.api_token      | sonarqube.jamf.build | field | api-key"
)

# ----

if ! bw status 2>/dev/null | grep -q '"status":"unlocked"'; then
  echo "ERROR: Bitwarden vault is not unlocked. Export BW_SESSION first." >&2
  exit 1
fi

echo "==> Fetching secrets from Bitwarden..."
bw sync --quiet

BW_ITEMS=$(bw list items)

trim() { printf '%s' "$1" | xargs; }

get_item_id() {
  printf '%s' "$BW_ITEMS" | jq -r --arg n "$1" '.[] | select(.name==$n) | .id'
}

get_secret() {
  local type="$1" item="$2" detail="$3"
  case "$type" in
    field)
      printf '%s' "$BW_ITEMS" | jq -r --arg n "$item" --arg f "$detail" \
        '.[] | select(.name==$n) | .fields[] | select(.name==$f) | .value'
      ;;
    ssh)
      local jq_field
      case "$detail" in
        private) jq_field="privateKey" ;;
        public)  jq_field="publicKey"  ;;
        *) echo "Unknown ssh detail: $detail" >&2; exit 1 ;;
      esac
      printf '%s' "$BW_ITEMS" | jq -r --arg n "$item" --arg f "$jq_field" \
        '.[] | select(.name==$n) | .sshKey[$f]'
      ;;
    attachment)
      local item_id tmpfile
      item_id=$(get_item_id "$item")
      tmpfile=$(mktemp)
      trap 'rm -f "$tmpfile"' RETURN
      bw get attachment "$detail" --itemid "$item_id" --output "$tmpfile" >/dev/null
      base64 < "$tmpfile"
      ;;
    *)
      echo "Unknown secret type: $type" >&2
      exit 1
      ;;
  esac
}

mkdir -p "$(dirname "$SECRETS_FILE")"

result="{}"
for entry in "${SECRETS[@]}"; do
  IFS='|' read -r output_path item_name type detail <<< "$entry"
  output_path=$(trim "$output_path")
  item_name=$(trim "$item_name")
  type=$(trim "$type")
  detail=$(trim "$detail")

  echo "  -> $output_path"
  value=$(get_secret "$type" "$item_name" "$detail")

  jq_path=$(printf '%s' "$output_path" | jq -R 'split(".")')
  result=$(printf '%s' "$result" | jq --arg v "$value" --argjson p "$jq_path" 'setpath($p; $v)')
done

# Save as JSON
printf '%s\n' "$result" > "$SECRETS_FILE"
chmod 600 "$SECRETS_FILE"
echo "==> Secrets cached to $SECRETS_FILE"
