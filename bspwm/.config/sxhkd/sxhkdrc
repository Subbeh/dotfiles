########################
## screenshot         ##
########################

# flamshot gui
@Print
  flameshot gui

# cropped screenshot
super + @Print
  $BIN_DIR/screenshot --selected

# fullscreen screenshot
ctrl + @Print
  $BIN_DIR/screenshot --fullscreen

