# exa
if [ -x "$(command -v exa)" ]; then
  alias l="exa --long --group-directories-first --group --icons"
  alias ll="exa --long --all --group-directories-first --group --icons --git"
  alias lt="exa --long --all --sort=modified --group-directories-first --group --icons --git"
  alias ltree="exa --long --all --sort=modified --group-directories-first --group --icons --git --tree --level=2"
fi

