## functions

# get tailscale IPs
ts() {
	tailscale status --json | jq '.Peer | .[] | .HostName + " " + .TailscaleIPs[1]' | tr -d '"' | column -t
}

# git commit --amend
gcmp() {
	if git fetch --dry-run 2>&1 | grep -Eq '\w+\.\.\w+'; then
		echo ERROR: remote branch is ahead
	else
		git commit --amend
		git push -f
	fi
}
