#!/bin/sh
# Generate a dircolors(1) database from a vivid theme.
#
# vivid only emits LS_COLORS; this converts that into the dircolors database
# format so the theme can be applied at runtime via `eval $(dircolors ...)`
# without depending on vivid. See env/.config/profile.d/20-theme.sh.
#
# Usage: gen-dircolors [theme.yml] [output]

set -eu

theme="${1:-${XDG_CONFIG_HOME:-$HOME/.config}/vivid/theme.yml}"
out="${2:-${XDG_CONFIG_HOME:-$HOME/.config}/.dircolors}"

command -v vivid >/dev/null || { echo "gen-dircolors: vivid not found" >&2; exit 1; }
[ -r "$theme" ] || { echo "gen-dircolors: theme not found: $theme" >&2; exit 1; }

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

{
	echo "# vim:ft=dircolors"
	echo "# See dircolors(1) and dircolors -p for file format"
	echo "# Generated from vivid theme: $theme"
	echo "# Regenerate with: gen-dircolors [theme.yml] [output]"
	echo
	# Terminal gating: reuse coreutils' canonical TERM/COLORTERM list
	dircolors -p | grep -E '^(TERM|COLORTERM) '
	echo
	# LS_COLORS -> dircolors database
	vivid generate "$theme" | awk '
		BEGIN {
			RS = ":"
			m["no"]="NORMAL"; m["fi"]="FILE"; m["rs"]="RESET"; m["di"]="DIR"; m["ln"]="LINK"
			m["mh"]="MULTIHARDLINK"; m["pi"]="FIFO"; m["so"]="SOCK"; m["do"]="DOOR"; m["bd"]="BLK"
			m["cd"]="CHR"; m["or"]="ORPHAN"; m["mi"]="MISSING"; m["su"]="SETUID"; m["sg"]="SETGID"
			m["ca"]="CAPABILITY"; m["tw"]="STICKY_OTHER_WRITABLE"; m["ow"]="OTHER_WRITABLE"
			m["st"]="STICKY"; m["ex"]="EXEC"
		}
		{
			gsub(/\n/, ""); if ($0 == "") next
			e = index($0, "="); if (e == 0) next
			k = substr($0, 1, e - 1); v = substr($0, e + 1)
			if (k in m) { print m[k], v; next }
			if (substr(k, 1, 1) == "*") {
				r = substr(k, 2)
				if (substr(r, 1, 1) == ".") print r, v   # *.ext -> .ext
				else print "*" r, v                       # *name -> *name
			}
		}
	'
} > "$tmp"

mv "$tmp" "$out"
trap - EXIT
echo "gen-dircolors: wrote $out" >&2
