#!/bin/sh

if [ -d "$1" ]; then
	onefetch --include-hidden --no-art --no-color-palette "$1" 2>/dev/null && exit 0
	tree -CL 3 --gitignore --noreport "$1" 2>/dev/null && exit 0
fi

case "${1##*.}" in
md | MD | mkd | markdown | rst)
	[ "$(tput colors)" -gt 8 ] && fmt='ansi'
	pandoc -t "${fmt:-plain}" "$1"
	;;
*) exit 1 ;;
esac

