[global]
    background = "#f0f0f0"
    foreground = "#101010"
    monitor = 0
    follow = mouse
    
    #width = 420
    #height = 300
    offset = 5x30

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 5
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/firefox -new-tab

    indicate_hidden = yes
    shrink = no
    transparency = 20
    separator_height = 2
    padding = 15
    horizontal_padding = 15
    frame_width = 2
    frame_color = "#d7d7af"
    separator_color = "#d7d7af"
    sort = no
    idle_threshold = 30
    font = FuraCode Nerd Font 8
    line_height = 6
    #notification_height = 30
    markup = full

    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 10
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = false
    hide_duplicate_count = yes
    show_indicators = no
    icon_position = left
    max_icon_size= 100
    sticky_history = no
    history_length = 3
    browser = qutebrowser
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 0

    ## mouse_left_click = do action
    ## mouse_middle_click = close_current
    mouse_right_click = close_all

[urgency_low]
    timeout = 4
    background = "#d7d7af"
    foreground = "#303030"

[urgency_normal]
    timeout = 8
    background = "#303030"
    foreground = "#d7d7d7"

[urgency_critical]
    timeout = 8
    background = "#b63b3b"
    foreground = "#d7d7d7"

## vim: ft=cfg
