! Colorscheme
  
#include </home/sysadm/.config/colorschemes/theme>

! URxvt
  
URxvt.scrollBar: false
URxvt.lineSpace: 1
URxvt.internalBorder: 24
URxvt.font: xft:FuraMono Nerd Font Mono:style=Regular:size=7.5
URxvt.boldFont: xft:FuraMono Nerd Font Mono:style=Bold:size=7.5
URxvt.italicFont: xft:FuraMono Nerd Font Mono:style=Italic:size=7.5
URxvt.boldItalicFont: xft:FuraMono Nerd Font Mono:style=Bold Italic:size=7.5
URxvt.cursorUnderline: true

! Perl
URxvt.perl-ext-common: selection-to-clipboard,default,matcher
URxvt.clipboard.autocopy: true
URxvt.keysym.M-c: perl:clipboard:copy
URxvt.keysym.M-v: perl:clipboard:paste
URxvt.url-launcher: /usr/bin/xdg-open
URxvt.matcher.button: 1
