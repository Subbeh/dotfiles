# vi: ft=sshconfig
StrictHostKeyChecking accept-new
ControlPath ${XDG_RUNTIME_DIR}/ssh.%C
ServerAliveInterval 300
ServerAliveCountMax 2
{{- if eq .Profile "work" }}
IdentityFile ~/.ssh/keys/id_laptop-work-ssh-key
{{- else if eq .Profile "personal" }}
IdentityFile ~/.ssh/keys/id_laptop-personal-ssh-key
{{- end }}

Host github.com
  User git
  IdentityFile ~/.ssh/keys/id_github-ssh-key
  StrictHostKeyChecking no
  IdentitiesOnly yes
